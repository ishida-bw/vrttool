# VRT設定
# Playwright 実行時に自動読み込みされます。

# 待機時間（ミリ秒）
# 各ページ遷移の前後で待機して、WAFやレート制限、表示の揺れを抑えます。
VRT_WAIT_MS=2000

# 画像比較の許容差分率
# 0.01 = 1% までの差分を許容します。
VRT_MAX_DIFF_RATIO=0.01

# 画像比較の許容差分ピクセル数
# 0 の場合は 1px でも差分があれば失敗です。
VRT_MAX_DIFF_PIXELS=0

# A/B の生画像を tests/vrt-snapshots に保存するか
# true: 保存する / false: 保存しない
VRT_SAVE_RAW_SCREENSHOTS=true

# Basic認証（任意）
# A側 = urls-a.txt、B側 = urls-b.txt
# 片側だけ設定する場合でも、ユーザー名とパスワードは必ず両方設定してください。
VRT_BASIC_AUTH_USERNAME_A=
VRT_BASIC_AUTH_PASSWORD_A=
VRT_BASIC_AUTH_USERNAME_B=cegbw
VRT_BASIC_AUTH_PASSWORD_B=NrqxdauR

# 共通フォールバック認証情報（任意）
# A/B 個別の認証情報が未設定の場合のみ使われます。
VRT_BASIC_AUTH_USERNAME=
VRT_BASIC_AUTH_PASSWORD=

# 参考: 差分ピクセル数を緩めたい場合
# VRT_MAX_DIFF_PIXELS=50

# スクリーンショット比較時にマスクするセレクター（任意）
# JSON配列形式またはカンマ区切りで指定できます。
# 例: VRT_MASK_SELECTORS=.a iframe,.b video
VRT_MASK_SELECTORS="
"

# 要素の位置やサイズ差を比較対象外にするセレクター（任意）
# A/B で位置がずれても差分エラーにしたくない要素を指定します。
VRT_IGNORE_POSITION_SELECTORS="
.header
"

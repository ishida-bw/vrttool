# Basic auth for Playwright navigation (optional)
# Keep actual credentials in .env (this file is just a template)
#
# Prefer side-specific credentials for each URL list:
#   A side -> urls-a.txt
#   B side -> urls-b.txt
VRT_BASIC_AUTH_USERNAME_A=
VRT_BASIC_AUTH_PASSWORD_A=
VRT_BASIC_AUTH_USERNAME_B=cegbw
VRT_BASIC_AUTH_PASSWORD_B=NrqxdauR

# Optional shared fallback (used only when A/B-specific values are omitted)
VRT_BASIC_AUTH_USERNAME=
VRT_BASIC_AUTH_PASSWORD=
